{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./client/src/*"]
    }
  },
  "include": ["client/src/**/*", "server/**/*"],
  "exclude": ["node_modules", "dist", "build"]
}