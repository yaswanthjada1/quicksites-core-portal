{
  "name": "quicksites-studio-workspace",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build:client": "cd client && npm run build",
    "electron:dev": "cross-env ELECTRON_START_URL=http://localhost:5173 electron .",
    "electron:prod": "npm run build:client && electron .",
    "dist": "npm run build:client && electron-builder --win nsis --x64"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^26.4.0",
    "electron-builder": "^24.6.0"
  },
  "build": {
    "appId": "com.quicksites.studio",
    "productName": "QuickSites Studio",
    "files": [
      "main.js",
      "server/**",
      "client/dist/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}